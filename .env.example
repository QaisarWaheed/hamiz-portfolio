# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/hamiz-portfolio

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-secure-random-string

# Admin — development uses plain ADMIN_PASSWORD; production requires ADMIN_PASSWORD_HASH (bcrypt)
# Hash: npm run hash-password <password> — escape $ in .env as \$  (e.g. \$2b\$10\$...)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=dev-only-plain-password
# ADMIN_PASSWORD_HASH=\$2b\$10\$production_only

# Cloudinary (thumbnail uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Public hero background video (direct URL to mp4/webm)
NEXT_PUBLIC_HERO_VIDEO_URL=https://assets.mixkit.co/videos/preview/mixkit-set-of-plane-spotlights-moving-in-the-dark-background-5566-large.mp4

# Optional: homepage stats count-up targets (otherwise uses API list lengths)
# NEXT_PUBLIC_STATS_CLIENTS_TARGET=100
# NEXT_PUBLIC_STATS_PROJECTS_TARGET=50

# When true, empty DB still serves lib/demo-content in production (optional)
# SHOW_DEMO_CONTENT=true
